# =============================================================================
# HubAssist backend environment template.
#
# Copy this file to `backend/.env` and fill in real values. The shape and
# defaults documented here must stay in sync with
# `src/config/validation.schema.ts` (the runtime Joi validator) and the
# Environment Variables Reference section of the root README.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string. Required.
DATABASE_URL=postgresql://postgres:password@localhost:5432/hubassist

# -----------------------------------------------------------------------------
# JWT / Auth
# -----------------------------------------------------------------------------
# Secret used to sign short-lived access tokens. Required. Use a long
# (32+ char) random string in production — rotate if compromised.
JWT_SECRET=change-me-in-production
# Access token TTL. Accepts ms-style durations (e.g. "15m", "1h", "2d").
JWT_EXPIRES_IN=1h
# Secret used to sign refresh tokens. Required. MUST differ from JWT_SECRET.
REFRESH_TOKEN_SECRET=change-me-in-production
# Refresh token TTL.
REFRESH_TOKEN_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Email (SMTP) — optional; required only if you enable email features.
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@hubassist.com

# -----------------------------------------------------------------------------
# Cloudinary (file uploads) — optional; required only if uploads are enabled.
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# -----------------------------------------------------------------------------
# Stellar / Contracts
# -----------------------------------------------------------------------------
# Network the backend should interact with. One of: testnet | mainnet.
STELLAR_NETWORK=testnet
# Deployed `workspace_booking` contract ID (starts with "C..."). Optional
# until the contract is deployed; required for booking on-chain calls.
WORKSPACE_BOOKING_CONTRACT_ID=
# Deployed `membership_token` contract ID. Optional until deployed.
MEMBERSHIP_TOKEN_CONTRACT_ID=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Runtime mode. One of: development | production | test.
NODE_ENV=development
# Allowed CORS origin (browser will be rejected if it doesn't match).
FRONTEND_URL=http://localhost:3000
