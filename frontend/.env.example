# =============================================================================
# HubAssist frontend environment template.
#
# Copy this file to `frontend/.env.local` for local development. Only
# variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# Public URL of the backend API (must include the /api suffix). Required.
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Stellar network the UI should reference. One of: testnet | mainnet.
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Canonical public URL of this app. Used in metadata, OG tags, and absolute
# links. In production, set to your deployed domain (e.g. https://hubassist.com).
NEXT_PUBLIC_APP_URL=http://localhost:3000
